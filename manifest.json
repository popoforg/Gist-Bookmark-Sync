{
  "manifest_version": 3,
  "name": "GitHub Gist Bookmark Sync",
  "version": "1.0.0",
  "description": "将 Chrome 书签同步到 GitHub Gist，或从 Gist 下载书签到本地",
  "permissions": [
    "bookmarks",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_badge": {
      "text": "",
      "color": "#dc3545"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
